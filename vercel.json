{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "wup-dashboard/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/health",   "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)",     "dest": "/index.html" }
  ]
}
